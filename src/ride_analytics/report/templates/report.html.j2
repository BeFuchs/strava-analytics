<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Ride Analytics — Training Report</title>
<script>{{ plotlyjs | safe }}</script>
<style>
  :root {
    --page: #f9f9f7;
    --surface: #fcfcfb;
    --ink: #0b0b0b;
    --ink-2: #52514e;
    --muted: #898781;
    --border: rgba(11, 11, 11, 0.10);
    --grid: #e1e0d9;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--page);
    color: var(--ink);
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    line-height: 1.45;
  }
  main { max-width: 980px; margin: 0 auto; padding: 32px 20px 56px; }
  header h1 { font-size: 26px; margin: 0 0 4px; }
  header p { margin: 0; color: var(--muted); font-size: 14px; }
  .tiles { display: flex; flex-wrap: wrap; gap: 12px; margin: 24px 0 8px; }
  .tile {
    flex: 1 1 150px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .tile .label { font-size: 13px; color: var(--ink-2); }
  .tile .value { font-size: 22px; font-weight: 600; margin-top: 2px; }
  section { margin-top: 32px; }
  h2 { font-size: 17px; margin: 0 0 4px; }
  .section-note { color: var(--muted); font-size: 13px; margin: 0 0 12px; }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
    overflow-x: auto;
  }
  .empty { color: var(--muted); font-size: 14px; padding: 20px; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th, td { padding: 8px 10px; text-align: right; font-variant-numeric: tabular-nums; }
  th:nth-child(-n+2), td:nth-child(-n+2) { text-align: left; }
  thead th {
    color: var(--ink-2);
    font-weight: 600;
    border-bottom: 1px solid var(--grid);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  thead th::after { content: "​"; font-size: 10px; color: var(--muted); }
  thead th.asc::after { content: " ▲"; }
  thead th.desc::after { content: " ▼"; }
  tbody tr { border-bottom: 1px solid var(--grid); }
  tbody tr:last-child { border-bottom: none; }
  td.source { color: var(--ink-2); font-size: 13px; }
  .footnote { color: var(--muted); font-size: 12.5px; margin-top: 8px; }
  .index-table { width: auto; min-width: 50%; }
  td.pos { color: #178a61; }
  td.neg { color: #cf5527; }
</style>
</head>
<body>
{% if comparison %}
<main>
  <header>
    <h1>Ride Analytics — Period Comparison</h1>
    <p>generated {{ generated }} · FTP {{ config.ftp_watts }} W ({{ ftp_wkg }} W/kg)</p>
  </header>

  <div class="tiles">
    <div class="tile"><div class="label">Period A</div><div class="value" style="font-size:16px">{{ period_a_label }}</div></div>
    <div class="tile"><div class="label">Period B</div><div class="value" style="font-size:16px">{{ period_b_label }}</div></div>
  </div>

  <section>
    <h2>Side by side</h2>
    <p class="section-note">
      Δ is period B minus period A.
      {% if not comparison.equal_length %}The periods differ in length — rows marked * are normalized per week; compare those, not the absolute totals.{% endif %}
    </p>
    <div class="card">
      <table>
        <thead>
          <tr><th>Metric</th><th>Period A</th><th>Period B</th><th>Δ</th></tr>
        </thead>
        <tbody>
          {% for row in comparison_rows %}
          <tr>
            <td style="text-align:left">{{ row.metric }}</td>
            <td>{{ row.a }}</td>
            <td>{{ row.b }}</td>
            <td class="{{ row.trend }}">{{ row.delta }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Power curve</h2>
    <p class="section-note">Best average power per window, each period aggregated separately.</p>
    <div class="card">
      {% if comparison_curves_div %}{{ comparison_curves_div | safe }}{% else %}<p class="empty">No power data in either period.</p>{% endif %}
    </div>
  </section>

  <section>
    <h2>Time in zones</h2>
    <p class="section-note">Share of riding time per zone, period A vs. period B.</p>
    <div class="card">
      {% if comparison_power_zones_div %}{{ comparison_power_zones_div | safe }}{% else %}<p class="empty">Power zones need power data in both periods.</p>{% endif %}
    </div>
    <div class="card" style="margin-top: 12px;">
      {% if comparison_hr_zones_div %}{{ comparison_hr_zones_div | safe }}{% else %}<p class="empty">HR zones need heart-rate data in both periods.</p>{% endif %}
    </div>
  </section>
</main>
{% else %}
<main>
  <header>
    <h1>Ride Analytics — Training Report</h1>
    <p>{{ totals.period }} · generated {{ generated }} · FTP {{ config.ftp_watts }} W ({{ ftp_wkg }} W/kg)</p>
  </header>

  <div class="tiles">
    <div class="tile"><div class="label">Rides</div><div class="value">{{ totals.rides }}</div></div>
    <div class="tile"><div class="label">Distance</div><div class="value">{{ totals.distance }}</div></div>
    <div class="tile"><div class="label">Moving time</div><div class="value">{{ totals.moving_time }}</div></div>
    <div class="tile"><div class="label">Total TSS</div><div class="value">{{ totals.tss }}</div></div>
  </div>

  <section>
    <h2>Training load</h2>
    <p class="section-note">Fitness (CTL), fatigue (ATL) and form (TSB) from daily training stress.</p>
    <div class="card">
      {% if pmc_div %}{{ pmc_div | safe }}{% else %}<p class="empty">No TSS data — rides carry neither power nor heart rate.</p>{% endif %}
    </div>
  </section>

  <section>
    <h2>Power curve</h2>
    <p class="section-note">
      Best average power across all rides.
      {% if ftp_estimate %}Estimated FTP: {{ ftp_estimate }} — best 20&nbsp;min × 0.95; the configured FTP stays authoritative for TSS/IF.{% endif %}
    </p>
    <div class="card">
      {% if power_curve_div %}{{ power_curve_div | safe }}{% else %}<p class="empty">No power data in this export.</p>{% endif %}
    </div>
  </section>

  <section>
    <h2>Durability</h2>
    <p class="section-note">
      Best power after 0–1000, 1000–2000, 2000–3000 and 3000+ kJ of accumulated work.
      The gap between the curves is your fatigue resistance; the table shows each bucket
      relative to fresh (1.00 = no fade).
    </p>
    <div class="card">
      {% if durability_div %}{{ durability_div | safe }}{% else %}<p class="empty">Durability needs rides with power data.</p>{% endif %}
    </div>
    {% if durability_index %}
    <div class="card" style="margin-top: 12px;">
      <table class="index-table">
        <thead>
          <tr><th>Window</th>{% for bucket in durability_index.buckets %}<th>{{ bucket }}</th>{% endfor %}</tr>
        </thead>
        <tbody>
          {% for row in durability_index.rows %}
          <tr>
            <td style="text-align:left">{{ row.window }}</td>
            {% for cell in row.cells %}<td>{{ cell }}</td>{% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </section>

  <section>
    <h2>Time in zones</h2>
    <p class="section-note">Share of riding time per power zone (Coggan, %FTP) and heart-rate zone (%threshold HR).</p>
    <div class="card">
      {% if power_zones_div %}{{ power_zones_div | safe }}{% else %}<p class="empty">No power data in this export.</p>{% endif %}
    </div>
    <div class="card" style="margin-top: 12px;">
      {% if hr_zones_div %}{{ hr_zones_div | safe }}{% else %}<p class="empty">No heart-rate data in this export.</p>{% endif %}
    </div>
  </section>

  <section>
    <h2>Climbs</h2>
    <p class="section-note">
      {{ n_climbs }} climbs detected (≥3 % avg gradient, ≥30 m gain, ≥500 m long) —
      the {{ climb_rows | length }} biggest by elevation gain.
    </p>
    <div class="card">
      {% if climb_rows %}
      <table>
        <thead>
          <tr>
            <th>Date</th><th>km</th><th>Gain (m)</th><th>Avg %</th><th>Max %</th>
            <th>Time</th><th>VAM</th><th>Ø W</th><th>W/kg</th><th>Pacing ¼ (W)</th><th>kJ before</th><th>Efforts</th>
          </tr>
        </thead>
        <tbody>
          {% for row in climb_rows %}
          <tr>
            <td style="text-align:left">{{ row.date }}</td>
            <td>{{ row.length }}</td>
            <td>{{ row.gain }}</td>
            <td>{{ row.avg_grad }}</td>
            <td>{{ row.max_grad }}</td>
            <td>{{ row.time }}</td>
            <td>{{ row.vam }}</td>
            <td>{{ row.avg_power }}</td>
            <td>{{ row.wkg }}</td>
            <td>{{ row.pacing }}</td>
            <td>{{ row.kj_before }}</td>
            <td>{{ row.efforts }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No climbs detected — rides carry no altitude/distance data, or the terrain is flat.</p>
      {% endif %}
    </div>
    {% if profile_div %}
    <div class="card" style="margin-top: 12px;">
      <p class="section-note" style="margin: 4px 0 0 8px;">Latest ride with climbs: {{ profile_caption }} — climbs highlighted.</p>
      {{ profile_div | safe }}
    </div>
    {% endif %}
    {% if evolution_div %}
    <div class="card" style="margin-top: 12px;">
      <p class="section-note" style="margin: 4px 0 0 8px;">Repeated climbs — time per effort over the season.</p>
      {{ evolution_div | safe }}
    </div>
    {% endif %}
  </section>

  <section>
    <h2>Rides</h2>
    <p class="section-note">Click a column header to sort.</p>
    <div class="card">
      <table id="rides">
        <thead>
          <tr>
            <th>Date</th><th>File</th><th>km</th><th>Moving</th>
            <th>NP (W)</th><th>IF</th><th>TSS</th><th>Ø HR</th><th>Max HR</th>
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
          <tr>
            <td>{{ row.date }}</td>
            <td class="source">{{ row.source }}</td>
            <td>{{ row.distance }}</td>
            <td>{{ row.duration }}</td>
            <td>{{ row.np }}</td>
            <td>{{ row['if'] }}</td>
            <td>{{ row.tss }}</td>
            <td>{{ row.avg_hr }}</td>
            <td>{{ row.max_hr }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% if any_estimated_tss %}<p class="footnote">* TSS estimated from heart rate (ride without power data).</p>{% endif %}
    </div>
  </section>
</main>
{% endif %}
<script>
  // Minimal column sort: numeric where possible, else text; duration hh:mm:ss aware.
  document.querySelectorAll("#rides thead th").forEach((th, col) => {
    th.addEventListener("click", () => {
      const tbody = th.closest("table").querySelector("tbody");
      const asc = !th.classList.contains("asc");
      th.closest("tr").querySelectorAll("th").forEach(h => h.classList.remove("asc", "desc"));
      th.classList.add(asc ? "asc" : "desc");
      const key = (tr) => {
        const text = tr.children[col].textContent.trim().replace("*", "");
        if (/^\d+:\d{2}:\d{2}$/.test(text)) {
          const [h, m, s] = text.split(":").map(Number);
          return h * 3600 + m * 60 + s;
        }
        const num = parseFloat(text.replace(",", ""));
        return Number.isNaN(num) ? text : num;
      };
      [...tbody.rows]
        .sort((a, b) => {
          const [ka, kb] = [key(a), key(b)];
          const cmp = typeof ka === "number" && typeof kb === "number"
            ? ka - kb : String(ka).localeCompare(String(kb));
          return asc ? cmp : -cmp;
        })
        .forEach(tr => tbody.appendChild(tr));
    });
  });
</script>
</body>
</html>
